{
  "name": "MERN e-commerce",
  "version": "1.0.0",
  "description": "MERN Stack E-Commerce Project",
  "main": "dist/backend/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "backend": "nodemon backend/index.ts",
    "frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run frontend\" \"npm run backend\"",
    "start": "node dist/backend/index.js",
    "install:all": "npm install --legacy-peer-deps",
    "install:dev": "npm install -D --legacy-peer-deps"
  },
  "keywords": [],
  "author": "HuXn WebDev",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "concurrently": "^8.2.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "express-formidable": "^1.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.6.3",
    "multer": "^1.4.5-lts.1",
    "nodemon": "^3.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.20.0",
    "@types/nodemon": "^1.19.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
